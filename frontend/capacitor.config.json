{
  "appId": "com.dropleapp.drople",
  "appName": "Drople",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#0d1117",
      "showSpinner": false
    }
  }
}
